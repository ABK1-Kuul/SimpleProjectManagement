# ─── Session (required for login) ───────────────────────────────────────
SESSION_SECRET="replace-with-a-long-random-string"

# ─── Supabase (server-side; use service role for login) ─────────────────
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Optional fallbacks if you already use Next-style public env names:
# NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
# SUPABASE_ANON_KEY="your-anon-jwt-key"

# Do NOT use NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (sb_publishable_...) on the server.
# That key format is not supported for server-side Supabase queries.

# ─── Optional AI / hosting ──────────────────────────────────────────────
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
