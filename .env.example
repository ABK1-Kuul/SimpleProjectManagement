# ─── JWT Auth Secret (required — used to sign login tokens) ─────────────────
# Generate a strong random string, e.g.: openssl rand -hex 32
SESSION_SECRET="replace-with-a-long-random-string"

# ─── Supabase (server-side; use service role key for full access) ────────────
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Optional fallbacks:
# NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
# SUPABASE_ANON_KEY="your-anon-jwt-key"

# Do NOT use NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (sb_publishable_...) on the server.

# ─── Optional ────────────────────────────────────────────────────────────────
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

