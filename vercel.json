{
  "buildCommand": "vite build && esbuild src/vercelApi.ts --bundle --platform=node --format=esm --outfile=api/index.js",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "api/index.js"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
